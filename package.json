{
  "name": "break-reminder",
  "version": "1.0.0",
  "description": "Stay healthy with break, water, and screen time reminders",
  "main": "main.js",
  "author": "Gopu <hello@gopu.work>",
  "scripts": {
    "postinstall": "node scripts/generate-icon.js",
    "build": "webpack --mode production",
    "start": "npm run build && node scripts/launch.js",
    "dev": "webpack --mode development && node scripts/launch.js",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "dist": "npm run build && electron-builder --win --mac --x64"
  },
  "build": {
    "appId": "work.gopu.break-reminder",
    "productName": "Break Reminder",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "Break Reminder"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "main.js",
      "preload.js",
      "preload-notif.js",
      "preload-modal.js"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "electron": "^27.1.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.5.4",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@fontsource/inter": "^5.0.16",
    "antd": "^5.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
